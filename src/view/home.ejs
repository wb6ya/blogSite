<%
  const featuredBlog = blogs?.[0];
  const latestBlogs = blogs || [];
  const cleanQuillContent = (html) => {
    if (!html) return "";
    return String(html)
      .replace(/<p>\s*(<br\s*\/?>)?\s*<\/p>/gi, "")
      .trim();
  };
  const formatDate = (value) => {
    if (!value) return "Freshly published";
    const parsed = new Date(value);
    if (Number.isNaN(parsed.getTime())) return value;
    return parsed.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric"
    });
  };
%>
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<main class="home-page">
  <section class="home-hero">
    <div class="home-hero__content">
      <p class="home-label">Modern Editorial Blog</p>
      <h1 class="home-title">Thoughtful stories with a polished reading experience.</h1>
      <p class="home-text">
        A cleaner magazine-style homepage, stronger visual rhythm, and better article
        previews make the whole site feel like a real publishing platform.
      </p>

      <div class="home-stats">
        <span><%= latestBlogs.length %> published posts</span>
        <span>Editorial-inspired layout</span>
        <span>Readable article flow</span>
      </div>

      <div class="hero-actions">
        <a class="hero-button" href="#latest-posts">Explore posts</a>
        <a class="hero-button hero-button--secondary" href="<%= featuredBlog ? `/blog/${featuredBlog.id}` : '#latest-posts' %>">Read featured</a>
        <% if (isAdminAuthorized) { %>
          <a class="hero-button" href="/admin/new">Write new post</a>
        <% } %>
      </div>
    </div>

    <aside class="hero-feature-card">
      <p class="hero-feature-card__eyebrow">Featured</p>
      <% if (featuredBlog) { %>
        <h2><%= featuredBlog.title %></h2>
        <p class="hero-feature-card__meta">
          <span><%= featuredBlog.author || "Anonymous" %></span>
          <span><%= formatDate(featuredBlog.createdAt) %></span>
        </p>
        <div class="hero-feature-card__excerpt">
          <%- cleanQuillContent(featuredBlog.content) || "Open the article to read the full story." %>
        </div>
        <a class="hero-feature-card__link" href="/blog/<%= featuredBlog.id %>">Continue reading</a>
      <% } else { %>
        <h2>Your next great post starts here.</h2>
        <p class="hero-feature-card__empty">Publish your first article to populate the homepage highlights.</p>
      <% } %>
    </aside>
  </section>

  <section class="home-highlights">
    <article class="highlight-card">
      <p class="home-label">Why it feels better</p>
      <h2 class="section-title">A blog should invite people to stay and read.</h2>
      <p class="section-note">
        This new structure gives you a proper hero, featured content, cleaner cards,
        and more breathing room between sections.
      </p>
    </article>

    <article class="newsletter-card">
      <p class="newsletter-card__label">Editor’s Note</p>
      <h3>Designed for content first.</h3>
      <p>
        Clear type scale, softer surfaces, and stronger call-to-action styling make
        the UI feel intentional without getting in the way.
      </p>
      <% if (isAdminAuthorized) { %>
        <a class="hero-button hero-button--secondary" href="/admin">Open admin dashboard</a>
      <% } %>
    </article>
  </section>

  <section class="home-section" id="latest-posts">
    <div class="section-header">
      <div>
        <p class="home-label">Latest Posts</p>
        <h2 class="section-title">Recent writing from the blog</h2>
        <p class="section-note">Browse the newest stories, ideas, and updates in a cleaner reading grid.</p>
      </div>
      <div class="section-header__actions">
        <span class="count-pill"><%= latestBlogs.length %> posts</span>
        <% if (isAdminAuthorized) { %>
          <a class="hero-button" href="/admin/new">Create New Blog</a>
        <% } %>
      </div>
    </div>

    <% if (!latestBlogs.length) { %>
      <div class="empty-card">
        <h3>No blogs available</h3>
        <p>Add a blog to your collection and it will appear here with the new editorial layout.</p>
      </div>
    <% } else { %>
      <div class="blog-grid">
        <% latestBlogs.forEach((blog, index) => { %>
          <article class="blog-card">
            <div class="blog-card__meta">
              <span><%= formatDate(blog.createdAt) %></span>
              <span><%= blog.author || "Anonymous" %></span>
            </div>

            <p class="blog-card__index">0<%= index + 1 %></p>
            <h3 class="blog-card__title">
              <a href="/blog/<%= blog.id %>"><%= blog.title %></a>
            </h3>

            <div class="blog-card__content">
              <%- cleanQuillContent(blog.content) || "No content available for this blog." %>
            </div>

            <div class="blog-footer">
              <a class="blog-link" href="/blog/<%= blog.id %>">Read article</a>
              <span class="blog-author">Post #<%= blog.id %></span>
            </div>

            <% if (isAdminAuthorized) { %>
              <div class="blog-admin-actions">
                <a class="hero-button" href="/admin/edit/<%= blog.id %>">Edit</a>
                <form action="/admin/delete/<%= blog.id %>" method="POST">
                  <button type="submit" class="hero-button hero-button--secondary">Delete</button>
                </form>
              </div>
            <% } %>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>
